--- !u!114 &518616856
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 518616854}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0421\u043E\u043B\u0434\u0430\u0442 \u044D\u043B\u0438\u0442\u043D\u043E\u0433\u043E
    \u043E\u0442\u0440\u044F\u0434\u0430 \u043F\u0435\u0445\u043E\u0442\u0438\u043D\u0446\u0435\u0432
    \u043A\u043E\u0440\u043E\u043B\u044F \u042D\u0448\u0430. \u041E\u0434\u0438\u043D
    \u0438\u0437 \u043D\u0435\u043C\u043D\u043E\u0433\u0438\u0445 \u0432\u044B\u0436\u0438\u0432\u0448\u0438\u0445
    \u0432 \u0431\u0438\u0442\u0432\u0435 \u043F\u0440\u0438 \u0421\u043B\u0430\u043D\u0434\u0435\u0440\u0441\u0435,
    \u043A\u043E\u0433\u0434\u0430 \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0441\u0440\u0430\u0436\u0435\u043D\u0438\u044F
    \u0443\u0431\u0438\u0442\u044B\u0435 \u0441\u043E\u043B\u0434\u0430\u0442\u044B
    \u043D\u0430\u0447\u0430\u043B\u0438 \u0432\u043E\u0441\u0441\u0442\u0430\u0432\u0430\u0442\u044C
    \u0438 \u0431\u0440\u043E\u0441\u0430\u0442\u044C\u0441\u044F \u043D\u0430 \u0441\u0432\u043E\u0438\u0445
    \u0431\u044B\u0432\u0448\u0438\u0445 \u0441\u043E\u0440\u0430\u0442\u043D\u0438\u043A\u043E\u0432.
    \u041E\u043D \u043D\u0435 \u0441\u0442\u0440\u0443\u0441\u0438\u043B \u043A\u0430\u043A
    \u043C\u043D\u043E\u0433\u0438\u0435, \u0430 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B
    \u0441\u0440\u0430\u0436\u0430\u0442\u044C\u0441\u044F \u0434\u0430\u0436\u0435
    \u0431\u0443\u0434\u0443\u0447\u0438 \u043E\u043A\u0440\u0443\u0436\u0451\u043D\u043D\u044B\u043C
    \u043C\u0435\u0440\u0442\u0432\u0435\u0446\u0430\u043C\u0438. \u041C\u0430\u0441\u0442\u0435\u0440\u0441\u0442\u0432\u043E
    \u0438 \u0442\u0432\u0451\u0440\u0434\u0430\u044F \u0440\u0443\u043A\u0430 \u043F\u043E\u043C\u043E\u0433\u043B\u0438
    \u0435\u043C\u0443 \u0432\u044B\u0436\u0438\u0442\u044C. \n\u0411\u044B\u043B
    \u043D\u0430\u0433\u0440\u0430\u0436\u0434\u0451\u043D \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0439
    \u0433\u0440\u0430\u043C\u043E\u0442\u043E\u0439 \u0438 \u0437\u0435\u043C\u043B\u044F\u043C\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435, \u043A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E,
    \u0435\u043C\u0443 \u043D\u0435 \u043F\u0440\u0438\u0433\u043E\u0434\u0438\u043B\u0438\u0441\u044C. 
    \n\u041F\u043E\u0441\u043B\u0435 \u043F\u0430\u0434\u0435\u043D\u0438\u044F \u043A\u043E\u0440\u043E\u043D\u044B
    \u0431\u044B\u043B \u043E\u0442\u043A\u0430\u043C\u0430\u043D\u0434\u0438\u0440\u043E\u0432\u0430\u043D
    \u0432 \u0434\u043E\u0437\u043E\u0440 \u0431\u0430\u0448\u043D\u0438, \u0433\u0434\u0435
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0435\u0442 \u043D\u0435\u0441\u0442\u0438
    \u0441\u043B\u0443\u0436\u0431\u0443. \n\n\u041C\u0430\u0441\u0442\u0435\u0440\u0441\u043A\u0438
    \u043E\u0431\u0440\u0430\u0449\u0430\u0435\u0442\u0441\u044F \u0441 \u043B\u044E\u0431\u044B\u043C
    \u043E\u0440\u0443\u0436\u0438\u0435\u043C \u0431\u043B\u0438\u0436\u043D\u0435\u0433\u043E
    \u0431\u043E\u044F. \u041C\u0435\u0442\u0430\u0435\u0442 \u0442\u043E\u043F\u043E\u0440\u044B
    \u0438 \u043A\u043E\u043F\u044C\u044F. \u0423\u043C\u0435\u0435\u0442 \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C\u0441\u044F
    \u0449\u0438\u0442\u0430\u043C\u0438.\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
